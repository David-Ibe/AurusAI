# FMP (Financial Modeling Prep) - Treasury rates, economic indicators
FMP_API_KEY=your-fmp-api-key

# Massive (Polygon.io) - Economic calendar (TMX Corporate Events)
MASSIVE_API_KEY=your-massive-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# TwelveData (gold price - Phase 3)
TWELVEDATA_API_KEY=

# NewsAPI (Phase 2)
NEWSAPI_API_KEY=

# Optional: set to "true" to disable scheduler (e.g. for dev)
# AURUS_DISABLE_SCHEDULER=false
